---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  heroHeader?: boolean;
  ogType?: "website" | "article";
  pubDate?: Date;
}

const { title, description, heroHeader = Astro.url.pathname === "/", ogType = "website", pubDate } =
  Astro.props;
const pageTitle = title === "wwwyo's blog" ? title : `${title} - wwwyo's blog`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title="wwwyo's blog" href="/rss.xml" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={ogType} />
    {pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}
  </head>
  <body>
    <div class="page">
      <header class:list={["site-header", { "site-header--hero": heroHeader }]}>
        <a href="/" class="site-title">wwwyo's blog</a>
        <nav class="site-nav">
          <a href="/about">About</a>
          <a href="https://tools.wwwyo.dev">Tools</a>
          <a href="/rss.xml" class="rss-link" aria-label="RSS">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 11a9 9 0 0 1 9 9" />
              <path d="M4 4a16 16 0 0 1 16 16" />
              <circle cx="5" cy="19" r="1" fill="currentColor" stroke="none" />
            </svg>
          </a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  .page {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }

  .site-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--spacing-sm) var(--spacing-md);
    padding: var(--spacing-lg) 0 var(--spacing-md);
  }

  .site-title {
    font-family: var(--font-mono);
    font-size: var(--font-size-mono);
    color: var(--muted-foreground);
    text-decoration: none;
  }

  .site-title:hover {
    color: var(--primary);
  }

  .site-header--hero .site-title {
    font-family: var(--font-body);
    font-size: var(--font-size-heading);
    font-weight: 700;
    letter-spacing: var(--letter-spacing-heading);
    font-feature-settings: "palt";
    color: var(--foreground);
  }

  .site-header--hero .site-title:hover {
    color: var(--primary);
  }

  .site-nav {
    display: flex;
    gap: var(--spacing-md);
  }

  .site-nav a {
    font-family: var(--font-mono);
    font-size: var(--font-size-mono);
    color: var(--muted-foreground);
    text-decoration: none;
  }

  .site-nav a:hover {
    color: var(--primary);
  }

  .rss-link {
    display: inline-flex;
    align-self: center;
  }

  main {
    padding: var(--spacing-md) 0 var(--spacing-xl);
  }
</style>
