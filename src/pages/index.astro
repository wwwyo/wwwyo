---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import { fetchExternalPosts } from "../lib/external-posts";

interface ListItem {
  title: string;
  url: string;
  pubDate: Date;
  source?: string;
}

const localPosts: ListItem[] = (await getCollection("blog")).map((post) => ({
  title: post.data.title,
  url: `/blog/${post.id}/`,
  pubDate: post.data.pubDate,
}));

const externalPosts: ListItem[] = await fetchExternalPosts();

const posts = [...localPosts, ...externalPosts].sort(
  (a, b) => b.pubDate.valueOf() - a.pubDate.valueOf(),
);

function formatDate(date: Date) {
  return date.toISOString().slice(0, 10).replaceAll("-", "/");
}
---

<Base title="wwwyo's blog" description="wwwyo's blog">
  <ul class="post-list">
    {
      posts.map((post) => (
        <li>
          <time class="post-date" datetime={post.pubDate.toISOString()}>
            {formatDate(post.pubDate)}
          </time>
          <span class="post-title">
            <a href={post.url}>{post.title}</a>
            {post.source && (
              <img
                class="post-source"
                src={`/icons/${post.source}.png`}
                alt={post.source}
                title={post.source}
                width="16"
                height="16"
              />
            )}
          </span>
        </li>
      ))
    }
  </ul>
</Base>

<style>
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-list li {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-md);
    padding: var(--spacing-sm) 0;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: var(--font-size-mono);
    color: var(--muted-foreground);
    white-space: nowrap;
  }

  .post-source {
    display: inline-block;
    vertical-align: -2px;
    margin-left: var(--spacing-xs, 0.375rem);
    border-radius: 3px;
  }
</style>
