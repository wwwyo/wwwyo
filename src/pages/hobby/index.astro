---
import { Image } from "astro:assets";
import Base from "../../layouts/Base.astro";
import { hobbyProjects } from "../../data/hobby";
---

<Base title="Hobby" description="個人プロジェクトの一覧">
  <article>
    <header class="post-header">
      <h1>Hobby</h1>
      <p class="page-description">趣味で作ったものを紹介。</p>
    </header>
    <ul class="project-list">
      {
        hobbyProjects.map((project) => (
          <li>
            <a class="project-link" href={`/hobby/${project.slug}/`}>
              {project.thumbnail ? (
                <Image
                  class="project-thumb"
                  src={project.thumbnail}
                  alt=""
                  width={416}
                  loading="lazy"
                />
              ) : (
                <span class="project-thumb project-thumb--empty" aria-hidden="true">
                  {project.title.charAt(0)}
                </span>
              )}
              <div class="project-body">
                <div class="project-heading">
                  <span class="project-title">{project.title}</span>
                  <span class="project-period">{project.period}</span>
                </div>
                <p class="project-summary">
                  {project.summary}
                  {project.stopped && <span class="project-stopped">（停止中）</span>}
                </p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </article>
</Base>

<style>
  .post-header {
    margin-bottom: var(--spacing-lg);
  }

  .post-header h1 {
    margin: 0;
  }

  .page-description {
    margin: var(--spacing-xs) 0 0;
    color: var(--muted-foreground);
  }

  .project-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .project-link {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-md);
    color: inherit;
    text-decoration: none;
  }

  .project-thumb {
    width: 208px;
    aspect-ratio: 16 / 9;
    height: auto;
    object-fit: cover;
    flex-shrink: 0;
    border-radius: var(--rounded-code);
    background-color: var(--muted);
  }

  .project-thumb--empty {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: var(--font-size-heading);
    color: var(--muted-foreground);
  }

  @media (max-width: 480px) {
    .project-thumb {
      width: 128px;
    }
  }

  .project-body {
    min-width: 0;
  }

  .project-heading {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--spacing-sm) var(--spacing-md);
  }

  .project-title {
    font-weight: 600;
  }

  .project-link:hover .project-title {
    color: var(--primary);
  }

  .project-period {
    font-family: var(--font-mono);
    font-size: var(--font-size-mono);
    color: var(--muted-foreground);
    white-space: nowrap;
  }

  .project-summary {
    margin: var(--spacing-xs) 0 0;
    color: var(--muted-foreground);
  }

  .project-stopped {
    color: var(--muted-foreground);
  }
</style>
